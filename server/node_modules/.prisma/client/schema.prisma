generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                 Int      @id @default(autoincrement())
  name               String
  email              String   @unique
  passwordHash       String
  role               String   @default("HOST")
  mustChangePassword Boolean  @default(true)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  assignedVisits     Visit[]  @relation("HostVisits")
}

model Visitor {
  id               Int      @id @default(autoincrement())
  name             String
  phone            String   @unique
  photoBase64      String
  organizationName String
  idProofNumber    String?
  vehicleNumber    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  visits           Visit[]
}

model Visit {
  id         Int       @id @default(autoincrement())
  visitId    String    @unique @default(cuid())
  visitorId  Int
  visitor    Visitor   @relation(fields: [visitorId], references: [id])
  hostId     Int
  host       User      @relation("HostVisits", fields: [hostId], references: [id])
  department String
  reason     String
  status     String    @default("PENDING")
  qrValue    String?
  inTime     DateTime?
  outTime    DateTime?
  createdAt  DateTime  @default(now())
  approvedAt DateTime?
  rejectedAt DateTime?
}
